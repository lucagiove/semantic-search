{
  "name": "semantic-search",
  "version": "0.1.0",
  "private": true,
  "description": "CLI tool for semantic search over PDF documents using local embeddings.",
  "type": "module",
  "bin": {
    "docsearch": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run tests/e2e",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "commander": "^14.0.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.4"
  }
}
